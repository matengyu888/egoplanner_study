Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Planning1
        - /State1
        - /State1/rmua_odom1
        - /Mapping1
      Splitter Ratio: 0.5
    Tree Height: 392
  - Class: rviz/Selection
